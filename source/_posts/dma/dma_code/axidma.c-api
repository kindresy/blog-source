		// memcpy sg test
		{
			uint64_t src_addr[10];
			uint64_t dst_addr[10];
			int len[10];
			for(i=0;i<10;i++)
			{
				len[i] = 0x1000;
				src_addr[i] = 0x200000000 + i*len[i] *2;
				dst_addr[i] = 0x200100000 + i*len[i] *2;
				memset((unsigned char *)src_addr[i], i+1, len[i]);
			}
			param.src_addr = src_addr;
			param.dst_addr = dst_addr;
			param.len = len;
			param.nums = 10;
			ret = axidma_memcpy_sg(1, 1, param, -1);
			for(n=0;n<param.nums;n++)
			{
				for(i=0;i<param.len[n];i++)
				{
					if(*(unsigned char *)(param.src_addr[n]+i) != *(unsigned char *)(param.dst_addr[n]+i))
					{
						error_flg++;
						printf("n=%d, i=%d, src_addr=0x%lx != dst_addr=0x%lx\n",n, i, *(unsigned char *)(param.src_addr[n]+i), *(unsigned char *)(param.dst_addr[n]+i));
					}
				}
			}
			if(error_flg == 0)
				printf("axidma_memcpy sg .......... ok\n");
			else
				printf("axidma_memcpy sg .......... fail\n");		
		}

		// memcpy sg test 2
		{
			uint64_t src_addr[10];
			uint64_t dst_addr[10];
			int len[10];
			for(i=0;i<10;i++)
			{
				len[i] = 0x1000;
				src_addr[i] = 0x200000000 + i*len[i] *2;
				dst_addr[i] = 0x200200000 + i*len[i] *2;
				memset((unsigned char *)src_addr[i], i+2, len[i]);
			}
			param.src_addr = src_addr;
			param.dst_addr = dst_addr;
			param.len = len;
			param.nums = 10;
			ret = axidma_memcpy_sg(1, 1, param, -1);
			for(n=0;n<param.nums;n++)
			{
				for(i=0;i<param.len[n];i++)
				{
					if(*(unsigned char *)(param.src_addr[n]+i) != *(unsigned char *)(param.dst_addr[n]+i))
					{
						error_flg++;
						printf("n=%d, i=%d, src_addr=0x%lx != dst_addr=0x%lx\n",n, i, *(unsigned char *)(param.src_addr[n]+i), *(unsigned char *)(param.dst_addr[n]+i));
					}
				}
			}
			if(error_flg == 0)
				printf("axidma_memcpy sg 2.......... ok\n");
			else
				printf("axidma_memcpy sg 2.......... fail\n");	
		}
		
		axidma_deinit(1);
	}
	
}

#endif
